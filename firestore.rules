rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isUser(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isGroupMember(groupId) {
      return isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.members;
    }

    match /users/{userId} {
      allow read, write: if isUser(userId);
    }

    match /groups/{groupId} {
      // Any authenticated user can create a group (and must include themselves in members)
      allow create: if isAuthenticated() && request.auth.uid in request.resource.data.members;
      // Allow read if user is in members (works for queries)
      allow read: if isAuthenticated() && request.auth.uid in resource.data.members;
      // Allow update if user is already a member, OR if they are adding themselves to members
      allow update: if isAuthenticated() && (
        request.auth.uid in resource.data.members ||
        request.auth.uid in request.resource.data.members
      );
      allow delete: if false;
    }

    match /items/{itemId} {
      allow read: if isAuthenticated() && (
        (resource.data.get('isGroup', false) == false && resource.data.ownerId == request.auth.uid) ||
        (resource.data.get('isGroup', false) == true && isGroupMember(resource.data.ownerId))
      );
      
      allow create: if isAuthenticated() && (
        (request.resource.data.get('isGroup', false) == false && request.resource.data.ownerId == request.auth.uid) ||
        (request.resource.data.get('isGroup', false) == true && isGroupMember(request.resource.data.ownerId))
      );
      
      allow update, delete: if isAuthenticated() && (
        (resource.data.get('isGroup', false) == false && resource.data.ownerId == request.auth.uid) ||
        (resource.data.get('isGroup', false) == true && isGroupMember(resource.data.ownerId))
      );
    }
  }
}
